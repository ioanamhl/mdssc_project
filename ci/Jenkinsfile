// ============================================================
// GreenCart Grocery — MDSSC Advanced CI/CD Pipeline — pipeline test v2
//
// Stages:
//   1. Checkout          — clone, tool checks, bundle source archive
//   2. Check Health      — MDSSC server health + workflow metadata
//   3. Source Code Scan  — direct upload scan + indirect branch scan
//   4. Build             — install deps (parallel), compile, package, Docker images
//   5. Artifact Scan     — scan all build outputs + final MDSSC summary
//   6. Deploy            — pm2 backend + pm2 serve frontend (static)
//
// MDSSC API methods used:
//   1. GET  /api/v1/health
//   2. GET  /api/v1/workflows/{workflowId}
//   3. POST /api/v1/scans/direct
//   4. GET  /api/v1/scans/{id}/overview
//   5. GET  /api/v1/scans/{id}
//   6. POST /api/v1/scans  (indirect repo scan)
// ============================================================

def mdssc

pipeline {
    agent any

    triggers {
        githubPush()
    }
    ///small chnage to trigger build
    options {
        timestamps()
        skipDefaultCheckout(false)
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    parameters {
        // ---- scan toggles ----
        booleanParam(name: 'RUN_SOURCE_SCAN',   defaultValue: true, description: 'Scan source archive with MDSSC (direct upload).')
        booleanParam(name: 'RUN_REPO_SCAN',     defaultValue: true, description: 'Scan git repository by branch reference (indirect). Requires MDSSC_WORKFLOW_ID.')
        booleanParam(name: 'RUN_ARTIFACT_SCAN', defaultValue: true, description: 'Scan build artifacts with MDSSC (direct upload).')
        booleanParam(name: 'RUN_DEPLOY',        defaultValue: true, description: 'Deploy to server with pm2 after all scans pass.')

        // ---- MDSSC connection ----
        string(name: 'MDSSC_SERVER',         defaultValue: 'http://35.156.106.42', description: 'MDSSC server base URL.')
        string(name: 'MDSSC_CREDENTIALS_ID', defaultValue: 'mdssc-api-key',        description: 'Jenkins secret-text credential ID for the MDSSC API key.')
        string(name: 'MDSSC_API_KEY_HEADER', defaultValue: 'apikey',               description: 'HTTP header name for the MDSSC API key.')

        // ---- scan options ----
        string(name: 'MDSSC_WORKFLOW_ID',             defaultValue: '', description: 'MDSSC workflow ID. Required for indirect repo scan.')
        string(name: 'MDSSC_SCAN_TIMEOUT',            defaultValue: '900', description: 'Max seconds to wait for a scan to complete.')
        string(name: 'MDSSC_POLL_INTERVAL',           defaultValue: '10',  description: 'Seconds between /overview poll requests.')
        choice(name: 'MDSSC_VULNERABILITY_THRESHOLD', choices: ['critical', 'high', 'medium', 'low'], description: 'Minimum severity that fails the build.')
        booleanParam(name: 'MDSSC_FAIL_ON_VULNERABILITIES', defaultValue: false, description: 'Fail build when vulnerabilities at or above threshold are found.')
        booleanParam(name: 'MDSSC_SKIP_LARGE_ARTIFACTS',    defaultValue: true,  description: 'Skip artifacts larger than MDSSC_MAX_UPLOAD_MB.')
        string(name: 'MDSSC_MAX_UPLOAD_MB', defaultValue: '100', description: 'Max artifact size (MB) allowed for upload.')
    }

    environment {
        BACKEND_DIR          = 'backend'
        FRONTEND_DIR         = 'frontend'
        ARTIFACT_DIR         = 'artifacts'
        COMPOSE_PROJECT_NAME = 'greencart'
        BACKEND_IMAGE        = 'greencart-backend'
        FRONTEND_IMAGE       = 'greencart-frontend'
        FRONTEND_PORT        = '3001'
    }

    // ============================================================
    stages {

        // ----------------------------------------------------------
        // 1. CHECKOUT
        //    Clone repo, verify tools, create source archive for scanning.
        // ----------------------------------------------------------
        stage('Checkout') {
            steps {
                checkout scm

                script {
                    mdssc = load 'ci/mdsscAdvanced.groovy'
                }

                sh '''
                    echo "=== Build Info ==="
                    echo "Branch : $(git rev-parse --abbrev-ref HEAD)"
                    echo "Commit : $(git rev-parse --short HEAD)"
                    echo "=== Tool Versions ==="
                    node --version
                    npm --version
                    docker --version
                    docker compose version
                '''

                sh 'rm -rf "$ARTIFACT_DIR" && mkdir -p "$ARTIFACT_DIR"'

                sh '''
                    echo "=== Bundling source archive for MDSSC ==="
                    tar -czf "$ARTIFACT_DIR/source-code.tar.gz"  \
                        --exclude=.git              \
                        --exclude=artifacts         \
                        --exclude=node_modules      \
                        --exclude="*/node_modules"  \
                        --exclude="*/dist"          \
                        --exclude="*/build"         \
                        --exclude="*/coverage"      \
                        --exclude="*.log"           \
                        .
                    echo "Archive size: $(du -sh $ARTIFACT_DIR/source-code.tar.gz | cut -f1)"
                '''
            }
        }

        // ----------------------------------------------------------
        // 2. CHECK HEALTH
        //    Verify MDSSC server is reachable.
        //    Fetch workflow metadata (StorageId + RepositoryId)
        //    needed for the indirect branch scan in the next stage.
        // ----------------------------------------------------------
        stage('Check Health') {
            steps {
                script {
                    // API method 1: GET /api/v1/health
                    mdssc.checkHealth([:])

                    // API method 2: GET /api/v1/workflows/{workflowId}
                    env.MDSSC_WF_STORAGE_ID    = ''
                    env.MDSSC_WF_REPOSITORY_ID = ''

                    if (params.MDSSC_WORKFLOW_ID?.trim()) {
                        def wf = mdssc.fetchWorkflow([:])
                        env.MDSSC_WF_STORAGE_ID    = wf.storageId    ?: ''
                        env.MDSSC_WF_REPOSITORY_ID = wf.repositoryId ?: ''
                        echo "Workflow — StorageId: ${env.MDSSC_WF_STORAGE_ID} | RepositoryId: ${env.MDSSC_WF_REPOSITORY_ID}"
                    } else {
                        echo 'No MDSSC_WORKFLOW_ID set — skipping workflow fetch.'
                    }
                }
            }
        }
        
        // ----------------------------------------------------------
        // 3. SOURCE CODE SCAN
        //    Direct scan: upload source-code.tar.gz → MDSSC scans it.
        //    Indirect scan: MDSSC pulls the git branch itself (no upload).
        //    Both run before build so a dirty codebase never gets built.
        // ----------------------------------------------------------
        stage('Source Code Scan') {
            steps {
                script {
                    env.MDSSC_SOURCE_SCAN_ID = ''
                    env.MDSSC_REPO_SCAN_ID   = ''

                    // API methods 3 + 4 + 5: POST /scans/direct → poll → GET /scans/{id}
                    if (params.RUN_SOURCE_SCAN) {
                        env.MDSSC_SOURCE_SCAN_ID = mdssc.scanFileDirect(
                            path : "${ARTIFACT_DIR}/source-code.tar.gz",
                            label: 'greencart-source-code'
                        ) ?: ''
                        echo "Source scan ID: ${env.MDSSC_SOURCE_SCAN_ID}"
                    }

                    // API methods 6 + 4 + 5: POST /scans (indirect) → poll → GET /scans/{id}
                    if (params.RUN_REPO_SCAN && params.MDSSC_WORKFLOW_ID?.trim()) {
                        def branchName = sh(
                            script: 'git rev-parse --abbrev-ref HEAD',
                            returnStdout: true
                        ).trim()
                        if (branchName == 'HEAD') branchName = 'main'

                        env.MDSSC_REPO_SCAN_ID = mdssc.scanRepositoryIndirect(
                            [branch: branchName, label: "greencart-repo-${branchName}"],
                            [storageId: env.MDSSC_WF_STORAGE_ID ?: '', repositoryId: env.MDSSC_WF_REPOSITORY_ID ?: '']
                        ) ?: ''
                        echo "Indirect repo scan ID: ${env.MDSSC_REPO_SCAN_ID}"
                    } else if (params.RUN_REPO_SCAN) {
                        echo 'Indirect scan skipped — MDSSC_WORKFLOW_ID not set.'
                    }
                }
            }
        }
        // ----------------------------------------------------------
        // 3.5. SECURITY SCAN 
        //    npm audit  — scanare vulnerabilități dependențe
        //    ESLint     — calitate cod frontend
        //    Rapoarte JSON arhivate în Jenkins
        // ----------------------------------------------------------
        stage('Security Scan') {
            steps {
                script {
                    echo '=========================================='
                    echo '   SECURITY SCAN — npm audit + ESLint'
                    echo '=========================================='

                    // ── Backend: npm audit ──
                    dir("${env.BACKEND_DIR}") {
                        sh 'npm ci --prefer-offline 2>/dev/null || npm ci'
                        sh 'npm audit --json > ../artifacts/backend-audit.json 2>/dev/null || true'

                        sh '''node -e "
                            const d = JSON.parse(require('fs').readFileSync('../artifacts/backend-audit.json','utf8'));
                            const v = d.metadata && d.metadata.vulnerabilities ? d.metadata.vulnerabilities : {};
                            console.log('');
                            console.log('==========================================');
                            console.log('   BACKEND npm audit REPORT');
                            console.log('==========================================');
                            console.log('  Critical : ' + (v.critical||0));
                            console.log('  High     : ' + (v.high||0));
                            console.log('  Moderate : ' + (v.moderate||0));
                            console.log('  Low      : ' + (v.low||0));
                            console.log('==========================================');
                        "'''
                    }

                    // ── Frontend: npm audit ──
                    dir("${env.FRONTEND_DIR}") {
                        sh 'npm ci --prefer-offline 2>/dev/null || npm ci'
                        sh 'npm audit --json > ../artifacts/frontend-audit.json 2>/dev/null || true'

                        sh '''node -e "
                            const d = JSON.parse(require('fs').readFileSync('../artifacts/frontend-audit.json','utf8'));
                            const v = d.metadata && d.metadata.vulnerabilities ? d.metadata.vulnerabilities : {};
                            console.log('');
                            console.log('==========================================');
                            console.log('   FRONTEND npm audit REPORT');
                            console.log('==========================================');
                            console.log('  Critical : ' + (v.critical||0));
                            console.log('  High     : ' + (v.high||0));
                            console.log('  Moderate : ' + (v.moderate||0));
                            console.log('  Low      : ' + (v.low||0));
                            console.log('==========================================');
                        "'''

                        sh 'npx eslint . --format json --output-file ../artifacts/eslint-report.json 2>/dev/null || true'
                        echo '✅ ESLint report saved'
                    }

                    archiveArtifacts artifacts: 'artifacts/backend-audit.json, artifacts/frontend-audit.json, artifacts/eslint-report.json',
                                    allowEmptyArchive: true,
                                    fingerprint: true

                    echo '=========================================='
                    echo '   SECURITY SCAN COMPLETE'
                    echo '=========================================='
                }
            }
        }
        // ----------------------------------------------------------
        // 4. BUILD
        //    Install backend + frontend dependencies in parallel.
        //    Compile frontend (React/Vite).
        //    Package artifacts + build Docker images.
        // ----------------------------------------------------------
        stage('Build') {
            steps {
                // Install dependencies in parallel (backend has no compile step)
                script {
                    parallel(
                        'Backend — npm ci': {
                            dir("${env.BACKEND_DIR}") {
                                sh 'npm ci'
                            }
                        },
                        'Frontend — npm ci + build': {
                            dir("${env.FRONTEND_DIR}") {
                                sh 'npm ci'
                                sh 'npm run build'
                            }
                        }
                    )
                }

                // Package + Docker images
                sh '''
                    echo "=== Packaging artifacts ==="
                    tar -czf "$ARTIFACT_DIR/frontend-dist.tar.gz"   -C "$FRONTEND_DIR/dist" .
                    tar -czf "$ARTIFACT_DIR/backend-source.tar.gz"  \
                        --exclude=node_modules                       \
                        --exclude=uploads                            \
                        -C "$BACKEND_DIR" .

                    echo "=== Building Docker images ==="
                    docker compose build backend frontend
                    docker image inspect "$BACKEND_IMAGE" "$FRONTEND_IMAGE" >/dev/null
                    docker save -o "$ARTIFACT_DIR/docker-images.tar" "$BACKEND_IMAGE" "$FRONTEND_IMAGE"

                    echo "=== Artifact sizes ==="
                    du -sh "$ARTIFACT_DIR"/*
                '''

                archiveArtifacts artifacts: "${ARTIFACT_DIR}/**", fingerprint: true
            }
        }

        // ----------------------------------------------------------
        // 5. ARTIFACT SCAN
        //    Scan every build output (frontend bundle, backend archive,
        //    Docker images) — excludes source-code.tar.gz (already scanned).
        //    Prints final summary with all scan IDs + report URLs.
        // ----------------------------------------------------------
        stage('Artifact Scan') {
            when {
                expression { return params.RUN_ARTIFACT_SCAN }
            }
            steps {
                script {
                    // API methods 3 + 4 + 5 repeated per artifact
                    def ids = mdssc.scanArtifacts(
                        artifactDir : "${ARTIFACT_DIR}",
                        excludeNames: ['source-code.tar.gz']
                    )
                    env.MDSSC_ARTIFACT_SCAN_IDS = ids.join(',')
                    echo "Artifact scan IDs: ${env.MDSSC_ARTIFACT_SCAN_IDS}"

                    // Collect all scan IDs from every stage and print summary
                    List<String> allIds = []
                    if (env.MDSSC_SOURCE_SCAN_ID?.trim()) allIds << env.MDSSC_SOURCE_SCAN_ID.trim()
                    if (env.MDSSC_REPO_SCAN_ID?.trim())   allIds << env.MDSSC_REPO_SCAN_ID.trim()

                    String artifactIds = env.MDSSC_ARTIFACT_SCAN_IDS ?: ''
                    if (artifactIds) {
                        artifactIds.split(',').findAll { it.trim() }.each { allIds << it.trim() }
                    }

                    mdssc.printFinalSummary([:], allIds, env.MDSSC_WF_REPOSITORY_ID ?: '')
                }
            }
        }

        // ----------------------------------------------------------
        // 6. DEPLOY
        //    Backend  → pm2 process (Node.js)
        //    Frontend → pm2 serve (static SPA, port 3001)
        //    Runs only when all previous stages pass.
        // ----------------------------------------------------------
        stage('Deploy') {
            when {
                expression { return params.RUN_DEPLOY }
            }
            steps {
                sh """
                    echo "=== Deploying Backend ==="
                    pm2 restart greencart-backend 2>/dev/null || \\
                    pm2 start ${WORKSPACE}/backend/server.js \\
                        --name greencart-backend \\
                        --cwd  ${WORKSPACE}/backend
                    pm2 save

                    echo "=== Deploying Frontend ==="
                    pm2 restart greencart-frontend 2>/dev/null || \\
                    pm2 serve  ${WORKSPACE}/frontend/dist ${FRONTEND_PORT} \\
                        --name greencart-frontend \\
                        --spa
                    pm2 save

                    echo "=== Running processes ==="
                    pm2 list
                """
            }
        }

    }
    // ============================================================

    post {
        success {
            echo 'GreenCart pipeline completed successfully — app is live.'
        }
        failure {
            echo 'Pipeline failed — deploy blocked. Check MDSSC scan output and console log above.'
        }
        always {
            // Clean only MDSSC temp files, not the entire workspace
            sh 'rm -f .mdssc-* 2>/dev/null || true'
        }
    }
}
